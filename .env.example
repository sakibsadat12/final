# QueueStorm Investigator — environment configuration
#
# The service runs fully deterministically with NONE of these set. Everything
# below is optional.

# Port to bind. Railway injects this automatically; defaults to 8000 locally.
# PORT=8000

# --- Optional LLM text-polish layer (OFF by default) ---
# When disabled, all responses come from deterministic templates. The LLM can
# only rewrite narrative text, never the scored decision fields.
# LLM_ENABLED=false
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_TIMEOUT_S=6

# --- Tunables (sane defaults already applied) ---
# DUPLICATE_WINDOW_S=300
